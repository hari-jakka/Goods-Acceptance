<mvc:View
    xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:upload="sap.m.upload"
    controllerName="zxpapap0001a.controller.Picture"
    xmlns:semantic="sap.f.semantic"
    displayBlock="true"
>
    <semantic:SemanticPage
        id="page"
        headerPinnable="false"
        toggleHeaderOnTitleClick="false"
        busy="{objectView>/busy}"
        busyIndicatorDelay="{objectView>/delay}"
    >
        <semantic:content>
        <VBox
                width="100%"
                direction="Column"
                id="vbox0"
                alignContent="Center"            >
                <items>
                    <Text xmlns="sap.m"                        
                        text="{i18n>lblEquipmentNumber}"
                        id="txtequi"
                        class="sapUiSmallMarginBegin sapUiSmallMarginEnd"
                    />
                    <Input id="inpequi"                        
                        class="sapUiSmallMarginBegin sapUiSmallMarginEnd"
                        editable="true"
                    />

            <upload:UploadSet
                id="UploadSet"
                instantUpload="true"
                showIcons="true"
                visible="{worklistView>/page/editable}"
                items="{path: '/AttachmentSet'}" multiple="true"
                terminationEnabled="true"
                maxFileNameLength="55"
                beforeUploadStarts="onBeforeUploadStarts"
                uploadCompleted="onUploadCompleted"
                class="sapUiResponsiveMargin"
            />
            </items>
            </VBox>
        </semantic:content>
        </semantic:SemanticPage>
</mvc:View>