<mvc:View
    xmlns:upload="sap.m.upload"
    controllerName="eu.aiden.ga.goodsacceptance.controller.Worklist"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:semantic="sap.f.semantic"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:ndc="sap.ndc"
>
    <semantic:SemanticPage
        id="page"
        headerPinnable="true"
        preserveHeaderStateOnScroll="false"
        toggleHeaderOnTitleClick="false"
        class="sapUiNoContentPadding"
    >
        <semantic:titleHeading>
            <Title
                id="worklistViewTitle"
                text="{worklistView>/viewTitle}"
                level="H2"
            />
        </semantic:titleHeading>

        <semantic:headerContent>
            <HBox alignItems="Center" justifyContent="SpaceBetween" wrap="Wrap">
                <Button
                    text="{i18n>lblCreateIncident}"
                    type="Attention"
                    press="onIncidentType01"
                    class=""
                />


                <Button
                    text="{i18n>lblHistory}"
                    press="onDeliveryHistoryPress"
                    width="auto"
                />

                  
            </HBox>
            <fb:FilterBar
                id="filterbar"
                showFilterConfiguration="false"
                showClearOnFB="true"
                useToolbar="false"
                clear=".onClearFB"
                showGoOnFB="false"
                search=".onSearch"
                filterChange=".onFilterChange"
            >
                <fb:filterGroupItems>
                    <fb:FilterGroupItem
                        name="StorageLoc"
                        label="{i18n>lblDepot}"
                        groupName="Group1"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <Input
                                id="depotFilter"
                                showClearIcon="true"
                                suggestionItems="{depots>/results}"
                                showSuggestion="true"
                                change=".onDepotChange"
                                liveChange="onLiveChangeDepot"
                            >
                                <suggestionItems>
                                    <core:Item
                                        key="{depots>Kunnr}"
                                        text="{depots>Kunnr} / {depots>InsphireCode} - {depots>DepotName} - {depots>City} - {depots>Address} - {depots>Country}"
                                    />
                                </suggestionItems>
                            </Input>
                        </fb:control>
                    </fb:FilterGroupItem>

                    <fb:FilterGroupItem
                        name="SubGroup"
                        label="{i18n>lblSubgroup}"
                        groupName="Group1"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="subgroupFilter"
                                items="{
                            path: '/ZCDS_EQUIP_SUBGROUP_SUGGEST',
                            sorter: { path: 'SubGroup' }
				}"
                                change="onSearch"
                            >
                                <core:Item
                                    key="{SubGroup}"
                                    text="{SubGroup}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>

                    <fb:FilterGroupItem
                        name="Supplier"
                        label="{i18n>lblSupplier}"
                        groupName="Group1"
                        visibleInFilterBar="true"
                    >
                        <fb:control>
                            <ComboBox
                                id="supplierFilter"
                                items="{
                            path: '/ZXPAP0002_SUPPLIER_SUGGEST',
                            sorter: { path: 'SupplierName' }
				}"
                                change="onSearch"
                            >
                                <core:Item
                                    key="{SupplierName}"
                                    text="{SupplierName}"
                                />
                            </ComboBox>
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>

            <Button
                    id="depotAccessBtn"
                    text="{i18n>lblDepotAccessMissing}"
                    press="onDepotAccessPress"
                    width="auto"
                    class="sapUiTinyMargin"
                />
        </semantic:headerContent>

        <semantic:content>
            <Table
                id="table"
                width="auto"
                items="{
                    path: '/ZOPEN_DELIVERY_OVERVIEW_GA',
                    sorter: {
                            path: 'DeliveryDate',
                            descending: false,
                            group: '.getGroup'
                    },
                    groupHeaderFactory: '.getGroupHeader',
                    suspended: true
                }"
                noDataText="{worklistView>/tableNoDataText}"
                busyIndicatorDelay="{worklistView>/tableBusyDelay}"
                growing="true"
                growingScrollToLoad="true"
                updateFinished=".onUpdateFinished"
            >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title
                            id="tableHeader"
                            text="{worklistView>/worklistTableTitle}"
                            visible="{=${device>/system/phone} ? false : true}"
                            level="H3"
                        />
                        <ToolbarSpacer />

                        <ndc:BarcodeScannerButton
                            id="barcodeScannerButton"
                            scanSuccess="onScanSuccess"
                            scanFail="onScanError"
                            inputLiveUpdate="onScanLiveupdate"
                            provideFallback="false"
                            disableBarcodeInputDialog="true"
                            dialogTitle="Barcode Scanner"
                        />
                        <SearchField
                            id="searchField"
                            tooltip="{i18n>lblSearch_}"
                            placeholder="{i18n>lblSearch_}"
                            width="20rem"
                            search=".onSearch"
                        >
                            <layoutData>
                                <OverflowToolbarLayoutData
                                    maxWidth="200px"
                                    priority="NeverOverflow"
                                />
                            </layoutData>
                        </SearchField>
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column>
                        <Text text="{i18n>lblItem}" />
                    </Column>

                    <Column
                        id="idPO"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text
                            text="{i18n>lblOrder}"
                            id="idPOCol"
                        />
                    </Column>

                    <Column>
                        <Text text="{i18n>lblMaterial}" />
                    </Column>

                    <Column
                        id="subGroupColumn"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text
                            text="{i18n>lblSubgroup}"
                            id="subGroupColumnTitle"
                        />
                    </Column>

                    <Column
                        id="supplierSerialnumberColumn"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text
                            text="{i18n>lblSupplierSerialNumber}"
                            id="supplierSerialNumberColumnTitle"
                        />
                    </Column>

                    <Column
                        id="outstandingColumn"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text
                            text="{i18n>lblQuantity}"
                            id="outstandingColumnTitle"
                        />
                    </Column>

                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="WithoutHeader"
                    >
                        <Text text="{i18n>lblDeliveryDate}" />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem
                        type="Navigation"
                        press=".onPress"
                    >
                        <cells>
                            <Text text="{DeliveryPosition}" />

                            <Text
                                text="{PurchaseOrder}"
                                id="txtPO"
                            />

                            <ObjectIdentifier
                                title="{MaterialDescription}"
                                text="{MaterialNumber}"
                            >
                                <customData>
                                    <core:CustomData
                                        key="mergeKey"
                                        value="Material"
                                    />
                                </customData>
                            </ObjectIdentifier>

                            <Text text="{SubGroup}" />
                            <Text text="{SupplierSerialnumber}" />

                            <VBox>
                                <Text
                                    text="{path:'ReceivedQuantity', type:'sap.ui.model.type.Integer'} {DeliveredUnit}"
                                />
                                <Text
                                    text="({path:'OpenQuantity', type:'sap.ui.model.type.Integer'} {DeliveredUnit} {i18n>lblOpen})"
                                />
                            </VBox>
                            <Text
                                text="{ path: 'DeliveryDate' , type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'yyyy-MM-dd'} }"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </semantic:content>
    </semantic:SemanticPage>

     <core:Fragment
        fragmentName="eu.aiden.ga.goodsacceptance.fragments.DeliveryHistoryDialog"
        type="XML"
    />
</mvc:View>
