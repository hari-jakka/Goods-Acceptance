<mvc:View
    controllerName="eu.aiden.ga.goodsacceptance.controller.Object"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:uxap="sap.uxap"
    xmlns:semantic="sap.m.semantic"
    xmlns:layout="sap.ui.layout"
>
    <uxap:ObjectPageLayout
        id="page"
        showTitleInHeaderContent="true"
        showAnchorBar="false"
        upperCaseAnchorBar="false"
        showFooter="true"
        busy="{objectView>/busy}"
    >
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>
                <uxap:expandedHeading>
                    <!-- <Title text="{EquipmentName}" wrapping="true"/> -->
                    <VBox>
                        <Title
                            text="{EquipmentName}"
                            wrapping="true"
                        />
                        <HBox visible="{=${device>/system/phone}}">
                            <Label
                                text="{i18n>lblDepot}"
                                vAlign="Middle"
                            />
                            <Text
                                text="{Depot}"
                                class="sapUiTinyMarginBegin"
                            />
                        </HBox>
                    </VBox>
                </uxap:expandedHeading>

                <uxap:snappedHeading>
                    <FlexBox
                        fitContainer="true"
                        alignItems="Center"
                    >
                        <VBox>
                            <Title
                                text="{EquipmentName}"
                                wrapping="true"
                            />
                            <HBox
                                alignItems="Start"
                                justifyContent="SpaceBetween"
                            >
                                <ObjectStatus
                                    title="{i18n>lblDelivery}"
                                    text="{DeliveryDocument}  -  {DeliveryPosition}"
                                />
                                <ObjectStatus
                                    title="{i18n>lblDepot}"
                                    text="{Depot}"
                                />
                            </HBox>
                        </VBox>
                    </FlexBox>
                </uxap:snappedHeading>
                <uxap:actions />
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>

        <uxap:headerContent>
            <FlexBox wrap="Wrap">
                <layout:VerticalLayout
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom"
                >
                    <ObjectStatus
                        title="{i18n>lblDelivery}"
                        text="{DeliveryDocument}  -  {DeliveryPosition}"
                    />
                    <ObjectStatus
                        title="{i18n>lblMaterial}"
                        text="{MaterialNumber} - {MaterialDescription}"
                    />
                    <ObjectStatus
                        title="{i18n>lblSubgroup}"
                        text="{SubGroup}"
                    />
                </layout:VerticalLayout>

                <layout:VerticalLayout
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom"
                >
                    <ObjectStatus
                        title="{i18n>lblSupplier}"
                        text="{SupplierName}"
                    />
                    <ObjectStatus
                        title="{i18n>lblMake}"
                        text="{MakeText}"
                    />
                    <ObjectStatus
                        title="{i18n>lblModel}"
                        text="{ModelText}"
                    />
                </layout:VerticalLayout>

                <layout:VerticalLayout
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom"
                >
                    <ObjectStatus
                        title="{i18n>lblQuantity}"
                        text="{path:'ReceivedQuantity', type:'sap.ui.model.type.Integer'} {UoM}"
                    />
                    <ObjectStatus
                        title="{i18n>lblOpen}"
                        text="{path:'OpenQuantity', type:'sap.ui.model.type.Integer'} {UoM}"
                    />
                    <ObjectStatus
                        title="{i18n>lblProcessed}"
                        text="{path:'ProcessedQuantity', type:'sap.ui.model.type.Integer'} {UoM}"
                    />
                </layout:VerticalLayout>

                <HBox>
                    <ObjectNumber
                        class="sapMObjectNumberLarge"
                        emphasized="false"
                        number="{Depot}"
                        unit="{i18n>lblDepot}"
                        textDirection="RTL"
                        visible="{=${device>/system/phone} ? false : true}"
                    />
                </HBox>
            </FlexBox>
        </uxap:headerContent>

        <uxap:sections>
            <uxap:ObjectPageSection
                id="sectionComposedItems"
                showTitle="false"
                titleUppercase="false"
                title=""
                titleVisible="false"
                visible="{objectView>/composedItems}"
            >
                <uxap:ObjectPageSubSection
                    id="subSectionComposedItems"
                    title=""
                    mode="Expanded"
                >
                    <uxap:blocks>
                        <core:Fragment
                            fragmentName="eu.aiden.ga.goodsacceptance.fragments.ComposedItemsList"
                            type="XML"
                        />
                    </uxap:blocks>
                </uxap:ObjectPageSubSection>
            </uxap:ObjectPageSection>

            <uxap:ObjectPageSection
                id="sectionQuestions"
                showTitle="false"
                titleUppercase="false"
                title=""
                titleVisible="false"
            >
                <uxap:ObjectPageSubSection
                    id="subSectionQuestions"
                    title=""
                    mode="Expanded"
                >
                    <uxap:blocks>
                        <VBox>
                            <VBox visible="{= ! ${BulkDelivery} }">
                                <core:Fragment
                                    fragmentName="eu.aiden.ga.goodsacceptance.fragments.Serialnumber"
                                    type="XML"
                                />
                            </VBox>

                            <VBox visible="{= ${LicensedFleet} === 'Y' }">
                                <core:Fragment
                                    fragmentName="eu.aiden.ga.goodsacceptance.fragments.LicensePlateVIN"
                                    type="XML"
                                />
                            </VBox>

                            <VBox visible="{BulkDelivery}">
                                <core:Fragment
                                    fragmentName="eu.aiden.ga.goodsacceptance.fragments.Quantity"
                                    type="XML"
                                />
                            </VBox>
                            <Panel
                                class="sapUiSmallMarginTop sapUiNoContentPadding"
                            >
                                <headerToolbar>
                                    <Toolbar>
                                        <Title
                                            text="{i18n>lblQuestions}"
                                        />
                                    </Toolbar>
                                </headerToolbar>
                                <List
                                    id="questionTableMain"
                                    width="auto"
                                    class="sapUiResponsiveMargin"
                                    showSeparators="None"
                                    items="{
                                    path: 'to_MamoCharact',
                                    factory: '._questionLineFactory',
                                    sorter : { path : 'SortField', descending: false }
                                }"
                                />
                            </Panel>
                            <Panel
                                class="sapUiSmallMarginTop sapUiNoContentPadding"
                            >
                                <headerToolbar>
                                    <Toolbar>
                                        <Title text="{i18n>lblIncidents}" />
                                    </Toolbar>
                                </headerToolbar>
                                <core:Fragment
                                    fragmentName="eu.aiden.ga.goodsacceptance.fragments.TopdeskTickets"
                                    type="XML"
                                />
                            </Panel>

                            <Panel
                                class="sapUiSmallMarginTop sapUiNoContentPadding"
                            >
                                <headerToolbar>
                                    <Toolbar>
                                        <Title text="{i18n>lblHistory}" />
                                    </Toolbar>
                                </headerToolbar>
                                <core:Fragment
                                    fragmentName="eu.aiden.ga.goodsacceptance.fragments.DeliveryHistory"
                                    type="XML"
                                />
                            </Panel>
                        </VBox>
                    </uxap:blocks>
                </uxap:ObjectPageSubSection>
            </uxap:ObjectPageSection>
        </uxap:sections>

        <uxap:footer>
            <Bar>
                <contentRight>
                    <Button
                        id="saveBtn"
                        text="{i18n>lblSave}"
                        press="onSave"
                        type="Emphasized"
                    />
                </contentRight>
            </Bar>
        </uxap:footer>
    </uxap:ObjectPageLayout>
</mvc:View>
