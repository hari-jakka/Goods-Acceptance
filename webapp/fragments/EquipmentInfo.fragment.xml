<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:f="sap.ui.layout.form">
	<!-- <VBox class="sapUiSmallMargin"> -->
		<f:SimpleForm
			editable="false"
			layout="ResponsiveGridLayout"
			title=""
			labelSpanXL="3"
			labelSpanL="3"
			labelSpanM="4"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="0"
			emptySpanL="4"
			emptySpanM="0"
			emptySpanS="0"
			columnsXL="2"
			columnsL="2"
			columnsM="2"
			singleContainerFullSize="false"
            backgroundDesign="Solid">
			<f:content>
	    	    <Label text="{i18n>detailPanelDeliveryLbl}"/> 
                <Text text="{Delivery}  -  {DeliveryPosnr}"/>
                <Label text="{i18n>detailPanelSerialLbl}" visible="{ path:'EquipmentID', formatter: '.formatter.hideWhenBulk'}"/>
                <Text text="{SerialNumber}" visible="{ path:'EquipmentID', formatter: '.formatter.hideWhenBulk'}"/>
                <Label text="{i18n>detailPanelMaterialLbl}"/>
                <Text text="{Material}"/>

                <Label text="{i18n>detailPanelSupplierLbl}"/>
                <Text text="{SupplierName}"/>
                <Label text="{i18n>detailPanelMakeLbl}"/>
                <Text text="{MakeText}"/>
                <Label text="{i18n>detailPanelModelLbl}"/>
                <Text text="{ModelText}"/>				
			</f:content>
		</f:SimpleForm>
</core:FragmentDefinition>