<core:FragmentDefinition
    xmlns:filterbar="sap.ui.comp.filterbar"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
>
    <Dialog id="historyDialog">
        <content>
            <filterbar:FilterBar
                id="historyFilterbar"
                showFilterConfiguration="false"
                showClearOnFB="true"
                useToolbar="false"
                showGoOnFB="false"
                clear=".onHistoryClear"
                search=".onHistorySearch"
                filterChange=".onHistoryFilterChange"
            >
                <filterbar:filterGroupItems>
                    <filterbar:FilterGroupItem
                        name="PostingDate"
                        label="{i18n>lblPastNumberOfDays}"
                        groupName="Group1"
                        visibleInFilterBar="true"
                    >
                        <filterbar:control>
                            <Input
                                id="historyDatePicker"
                                change=".onHistorySearchChange"
                                type="Number"
                                value="5"
                            />
                        </filterbar:control>
                    </filterbar:FilterGroupItem>

                    <filterbar:FilterGroupItem
                        name="Search"
                        label="{i18n>lblSearch}"
                        groupName="Group1"
                        visibleInFilterBar="true"
                    >
                        <filterbar:control>
                            <Input
                                id="historySearch"
                                showClearIcon="true"
                                change=".onHistorySearchChange"
                            />
                        </filterbar:control>
                    </filterbar:FilterGroupItem>
                </filterbar:filterGroupItems>
            </filterbar:FilterBar>
            <Table
                id="historyDialogTable"
                inset="false"
                items="{
                path: '/ZCDS_HISTORY_GA',
                suspended: true
            }"
            >
                <columns>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblSupplier}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblDelivery}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblPostingNr}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblMaterial}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblSubgroup}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblSerialNumber}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblSupplierSerialNumber}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblMake}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblModel}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblPostingDate}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblPostingTime}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblPostedBy}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblPostingStatus}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblQTYAccepted}" />
                    </Column>
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>lblUoM}" />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                            <VBox>
                                <Text text="{Supplier}" />
                                <Text text="{SupplierName}" />
                            </VBox>
                            <Text
                                text="{DeliveryDocument} - {DeliveryPosition}"
                            />
                            <Text text="{Postingnr}" />
                            <VBox>
                                <Text text="{Material}" />
                                <Text text="{MaterialDescription}" />
                            </VBox>
                            <Text text="{Subgroup}" />
                            <Text text="{SerialNumber}" />
                            <Text text="{VendorSerialNumber}" />
                            <Text text="{Make}" />
                            <Text text="{Model}" />
                            <Text
                                text="{
                        path: 'PostingDate',
                        type: 'sap.ui.model.type.DateTime',
                        formatOptions: {
                            pattern: 'dd.MM.YYYY'
                        }
                    }"
                            />
                            <Text
                                text="{
                        path: 'PostingTime',
                        type: 'sap.ui.model.type.TimeOfDay',
                        formatter: '.formatter.formatMsTime'
                    }"
                            />
                            <Text text="{PostedBy}" />
                            <core:Icon
                                src="{ path: 'PostingStatus', formatter: '.formatter.iconForStatus' }"
                                color="{ path: 'PostingStatus', formatter: '.formatter.colorForStatus' }"
                                size="1rem"
                            />
                            <Text
                                text="{path: 'AcceptedQuantity', formatter: '.formatter.IntegerOrFloat'}"
                            />
                            <Text text="{UoM}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <endButton>
            <Button
                text="{i18n>lblClose}"
                press=".onHistoryDialogClose"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
