<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"	
    xmlns:f="sap.ui.layout.form"
>
    <Dialog id="topdeskInfoDialog" 
        title="TOPdesk"
        state="Information">

		<content>
			<VBox class="sapUiMediumMargin">
				<Title text="{i18n>Obsolete}"/>
                <TextArea id="deviationLongtext" 
                    class="sapUiSmallMarginTop"
                    cols="40"
                    rows="6"
                    editable="false"/>
				<Button
                    id="topdeskLink"
                    class="sapUiSmallMarginTop"
					text="{i18n>Obsolete}"
                    press="onNavToTopDesk"/>
			</VBox>
		</content>


        <beginButton>
            <Button
                text="{i18n>filterDialogCloseBtn}"
                press=".onCloseTopdeskInfoDialog"
            />
        </beginButton>
    </Dialog>
</core:FragmentDefinition>