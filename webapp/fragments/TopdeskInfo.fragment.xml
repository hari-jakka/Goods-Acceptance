<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    id="topdeskDialogFragment"
>
    <Dialog
        id="topdeskInfoDialog"
        title="TOPdesk"
        state="Information"
    >
        <content>
            <VBox class="sapUiMediumMargin">
                <Label text="{i18n>lblDepot}:" />
                <ComboBox
                    id="topdeskDepot"
                    showClearIcon="true"
                    items="{depots>/results}"
                >
                    <items>
                        <core:ListItem
                            key="{depots>Kunnr}"
                            text="{depots>Kunnr} / {depots>Inspire_Code} - {depots>DepotName} - {depots>City} - {depots>Address} - {depots>Country}"
                        />
                    </items>
                </ComboBox>

                <Label text="{i18n>Obsolete}:" />
                <TextArea id="topdeskRemarks" />
            </VBox>
        </content>

        <beginButton>
            <Button
                text="{i18n>lblCreate}"
                press=".onCloseTopdeskCreateDialog"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>lblClose}"
                press=".onCloseTopdeskInfoDialog"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
