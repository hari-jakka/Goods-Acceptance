<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:upload="sap.m.upload">
    <Dialog id="notifDialog"
        title="{i18n>notifDialogTitle}"
        escapeHandler=".notifDialogEscapeHndlr">
        
        <VBox class="sapUiSmallMarginBeginEnd sapUiMediumMarginTopBottom">
            <Label text="{i18n>notifDialogDeviationLabel}"/>
            <TextArea id="deviationLongtext" 
                placeholder="{i18n>notifDialogDeviationPlaceholder}"
                cols="40"
                rows="6"/>
        </VBox>

        <upload:UploadSet
            id="UploadSet"
            mode="None"
            multiple="true"
            instantUpload="false"
            showIcons="true"
            visible="{worklistView>/page/editable}"
            uploadButtonInvisible="false"
            terminationEnabled="true"
            maxFileNameLength="55"
            beforeUploadStarts="onBeforeUploadStarts"
            uploadCompleted="onUploadCompleted"
            class="sapUiResponsiveMargin"
        />
        <endButton>
            <Button 
                text="{i18n>cmpItmLstOkButton}"
                press="onCloseNotifDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>