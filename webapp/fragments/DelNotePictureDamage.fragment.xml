<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:upload="sap.m.upload"
    xmlns:u="sap.ui.unified"
    xmlns:l="sap.ui.layout"
>
    <Dialog
        id="DelNotePictureDamageDialog"
        title="{i18n>lblDamage
}"
    >
        <l:VerticalLayout>
            <List items="{
			path: 'to_NotifImage'
		}">
                <CustomListItem>
                    <HBox>
                        <core:Icon
                            size="2rem"
                            src="sap-icon://attachment-photo"
                            class="sapUiSmallMarginBegin sapUiSmallMarginTopBottom"
                        />
                        <VBox
                            class="sapUiSmallMarginBegin sapUiSmallMarginTopBottom"
                        >
                            <Link
                                text="{Description}"
                                target="{DocumentId}"
                                press="showDelNoteImage"
                            />
                            <Label text="{ProductId}" />
                        </VBox>
                    </HBox>
                </CustomListItem>
            </List>

            <l:VerticalLayout>
                <u:FileUploader
                    id="fileUploaderDamage"
                    name="myFileUpload"
                    uploadUrl="upload/"
                    tooltip="Upload your file to the local server"
                    uploadComplete="handleUploadComplete"
                />
                <Button
                    text="{i18n>lblUploadFile}"
                    press="handleUploadPressDamage"
                />
            </l:VerticalLayout>
        </l:VerticalLayout>

        <endButton>
            <Button
                text="{i18n>lblClose}"
                press="onClosePictureDialogDamage"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
