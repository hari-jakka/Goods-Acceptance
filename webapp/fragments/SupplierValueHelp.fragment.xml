<core:FragmentDefinition
	xmlns="sap.ui.comp.valuehelpdialog"
	xmlns:m="sap.m"
	xmlns:fb="sap.ui.comp.filterbar"
	xmlns:core="sap.ui.core">
	<ValueHelpDialog
		title="{i18n>lblSupplier}"
		ok=".onVHSupplierOk"
		cancel=".onVHSupplierCancel"
		afterClose=".onVHSupplierAfterClose"
		supportRanges="false"
		key="Supplier"
		descriptionKey="SupplierName">
		<filterBar>
			<fb:FilterBar advancedMode="true" search=".onVHSupplierSearch" isRunningInValueHelpDialog="true">
				<fb:filterGroupItems>
					<fb:FilterGroupItem
						groupName="__$INTERNAL$"
						name="Supplier"
						label="{i18n>lblSupplierId}"
						visibleInFilterBar="true">
						<fb:control>
							<m:Input name="Supplier" />
						</fb:control>
					</fb:FilterGroupItem>
					<fb:FilterGroupItem
						groupName="__$INTERNAL$"
						name="SupplierName"
						label="{i18n>lblSupplierName}"
						visibleInFilterBar="true">
						<fb:control>
							<m:Input name="SupplierName" />
						</fb:control>
					</fb:FilterGroupItem>
				</fb:filterGroupItems>
			</fb:FilterBar>
		</filterBar>
	</ValueHelpDialog>
</core:FragmentDefinition>